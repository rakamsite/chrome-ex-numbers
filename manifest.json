{
  "manifest_version": 3,
  "name": "Torob Shop Number Saver",
  "version": "1.0.0",
  "description": "Saves phone numbers from Torob shop pages and scans other sites for Iranian mobile numbers, emails, and CMS type.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Torob Shop Number Saver",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/gray-16.png",
      "32": "icons/gray-32.png",
      "48": "icons/gray-48.png",
      "128": "icons/gray-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/gray-16.png",
    "32": "icons/gray-32.png",
    "48": "icons/gray-48.png",
    "128": "icons/gray-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "utils.js",
        "content-script.js"
      ],
      "run_at": "document_idle",
      "exclude_matches": [
        "*://basalam.com/*",
        "*://*.basalam.com/*"
      ]
    }
  ]
}
